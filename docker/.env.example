NEXUS_LOG_MODE=dev
LOG_LEVEL=info
NEXUS_TENANT_ID=default
NEXUS_INFRA_MODE=memory
FEISHU_ENCRYPT_KEY=

# 默认/兜底模型；模型前缀决定 ProviderRouter 选择哪个 Provider
# claude-* → AnthropicProvider, gpt-*/o* → OpenAIProvider, local-* → LocalPhaseOneProvider
NEXUS_DEFAULT_MODEL=local-phase1-mvp

# Provider API keys，至少配置一个用于真实推理；都未配置时回落到内置 local provider
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
OPENAI_API_KEY=
OPENAI_BASE_URL=

# 可选 YAML/JSON 配置文件覆盖每个 Agent 的 provider/model（与 ENV 同时生效，ENV 优先）
# NEXUS_AGENT_CONFIG_PATH=./config/agents.yaml

# 每个 Agent 单独的模型覆盖示例（命名规则：NEXUS_AGENT_<AGENT_ID_UPPER_SNAKE>_MODEL）
# NEXUS_AGENT_REQUIREMENT_ANALYST_MODEL=claude-sonnet-4-5
# NEXUS_AGENT_REQUIREMENT_ANALYST_PROVIDER=anthropic
# NEXUS_AGENT_TASK_PLANNER_MODEL=gpt-4o
# NEXUS_AGENT_TASK_PLANNER_PROVIDER=openai
# NEXUS_AGENT_REMINDER_MODEL=gpt-4o-mini

# LLM 意图分类器配置；未配置任何真实 provider 时自动回落到关键词启发式
# NEXUS_INTENT_MODEL=gpt-4o-mini
# NEXUS_INTENT_CONFIDENCE_THRESHOLD=0.5
# NEXUS_INTENT_TIMEOUT_MS=8000

# 联网搜索 Provider（二选一即可，都未配置则 ai.web.search 返回错误）
# TAVILY_API_KEY=
# BRAVE_API_KEY=

# 意图识别（默认按 LLM Provider 自动选 gpt-4o-mini / claude-haiku-4-5）
# NEXUS_INTENT_MODEL=gpt-4o-mini
# NEXUS_INTENT_CONFIDENCE_THRESHOLD=0.5
# NEXUS_INTENT_CLARIFICATION_THRESHOLD=0.2   # 信心低于此 + 关键词无命中时要求用户澄清；0=关闭
# NEXUS_INTENT_TIMEOUT_MS=8000
# NEXUS_INTENT_CACHE_TTL_SEC=60              # 同 tenantId+text 缓存秒数
# NEXUS_INTENT_COST_SENSITIVE=false          # 同分时优先选 low-tier (haiku/mini)
# NEXUS_INTENT_EXECUTION_KEYWORDS=代码,部署,测试,implement,deploy
# NEXUS_INTENT_CONNECTION_KEYWORDS=通知,会议,文档,notify,meeting

# Compact L4 LLM 配置（不配置时按 Provider 选 claude-haiku / gpt-4o-mini）
# NEXUS_COMPACT_MODEL=claude-haiku-4-5
# Compact L4 保留最近 N 轮对话（默认 4，仅压缩中间）
# NEXUS_COMPACT_KEEP_RECENT_TURNS=4

# SkillStore 文件系统目录（infraMode=memory 或 DB 未配置时使用）
# NEXUS_SKILL_DIR=.nexus/skills

# 审批策略（默认 standard，R2+ 进入审批）
# NEXUS_APPROVAL_POLICY=auto

# 每用户限流（条/分钟）
# NEXUS_RATE_LIMIT_PER_USER=120
